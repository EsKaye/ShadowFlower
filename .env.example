# ShadowFlower Environment Configuration

# =============================================================================
# REQUIRED: Core Service Configuration
# =============================================================================

# Base URL for GameDin API endpoints
GAMEDIN_BASE_URL=https://api.gamedin.xyz

# API key for ShadowFlower authentication (required for protected routes)
SHADOWFLOWER_API_KEY=your_shadowflower_api_key_here

# Secret key for Vercel cron authentication on scheduled moderation route
# Required for scheduled moderation jobs to run via Vercel cron
# Vercel sends Authorization: Bearer <CRON_SECRET> when CRON_SECRET is configured
# The cron path is: /api/jobs/moderation/schedule
CRON_SECRET=your_cron_secret_here_minimum_32_characters

# API key for server-to-server authentication with GameDin
GAMEDIN_SHADOWFLOWER_API_KEY=your_gamedin_shadowflower_api_key_here

# Allowed CORS origin (restrict to specific domain in production)
ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# OPTIONAL: Upstash Redis for Distributed Coordination
# =============================================================================

# Required for production-grade rate limiting, replay protection, and job locking
# If not configured, these features will degrade gracefully (see documentation)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token-here

# =============================================================================
# OPTIONAL: HMAC Signing for Inter-Service Communication
# =============================================================================

# Secret key for HMAC signature verification on protected routes
# Used for enhanced security between GameDin and ShadowFlower
SHADOWFLOWER_SIGNING_SECRET=your_signing_secret_here_minimum_32_characters

# Secret key for HMAC signing requests to GameDin
# Used when GAMEDIN_SIGNING_SECRET is configured in GameDin client
GAMEDIN_SIGNING_SECRET=your_gamedin_signing_secret_minimum_32_characters

# Note: For GameDin contract compliance, use SHADOWFLOWER_SIGNING_SECRET
# This is the shared secret used for the exact GameDin signing contract:
# signature = HMAC-SHA256(SHADOWFLOWER_SIGNING_SECRET, timestamp + ":" + nonce + ":" + body)
# Base64URL encoding, Unix seconds timestamp, 300 second freshness window

# =============================================================================
# OPTIONAL: Admin Access Configuration
# =============================================================================

# Admin key for accessing protected admin endpoints
# Required for admin gate functionality
SHADOWFLOWER_ADMIN_KEY=your_shadowflower_admin_key_here

# =============================================================================
# OPTIONAL: AI Provider Configuration
# =============================================================================

# Gemini API key for content moderation analysis
# Required if using Gemini provider
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# OPTIONAL: Discord Notification Configuration
# =============================================================================

# Discord webhook URL for sending notifications
# Required for Discord notifications
DISCORD_WEBHOOK_URL=

# =============================================================================
# OPTIONAL: Discord Bot Interaction Configuration
# =============================================================================

# Enable Discord bot slash command interactions
# Set to 'true' to enable Discord bot slash commands, 'false' to disable
# Default: false (Discord interactions disabled by default)
ENABLE_DISCORD_INTERACTIONS=false

# Discord channel IDs for different notification types
DISCORD_ALERT_CHANNEL_ID=your_alert_channel_id_here
DISCORD_DIGEST_CHANNEL_ID=your_digest_channel_id_here
DISCORD_ADMIN_CHANNEL_ID=your_admin_channel_id_here

# =============================================================================
# OPTIONAL: Discord Bot/App Configuration
# =============================================================================

# Discord Application ID (from Discord Developer Portal)
# Required for Discord slash commands
DISCORD_APPLICATION_ID=your_discord_application_id_here

# Discord Public Key (from Discord Developer Portal)
# Required for Discord interaction signature verification
# Note: Requires @noble/ed25519 package for proper Ed25519 verification
DISCORD_PUBLIC_KEY=your_discord_public_key_here

# Discord Bot Token (from Discord Developer Portal)
# Required for Discord bot functionality
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord Guild ID to restrict bot to specific server
# Optional: If not set, bot can be used in any guild (not recommended for production)
DISCORD_ALLOWED_GUILD_ID=your_allowed_guild_id_here

# Discord Channel IDs to restrict bot commands to specific channels
# Optional: Comma-separated list of channel IDs
DISCORD_ALLOWED_CHANNEL_IDS=your_allowed_channel_ids_here

# Discord Role IDs to restrict bot commands to specific roles
# Optional: Comma-separated list of role IDs
# Note: Role-based permission enforcement requires Discord API calls (not yet implemented)
DISCORD_ALLOWED_ROLE_IDS=your_allowed_role_ids_here

# Discord User IDs to allow bot commands for specific users
# Optional: Comma-separated list of user IDs (for admin override)
DISCORD_ALLOWED_USER_IDS=your_allowed_user_ids_here

# =============================================================================
# OPTIONAL: Service Configuration
# =============================================================================

# Node environment (development | production)
NODE_ENV=development

# Port for local development (optional, Vercel uses its own)
PORT=3000

# =============================================================================
# OPTIONAL: Moderation Configuration
# =============================================================================

# Default batch size for moderation jobs
DEFAULT_BATCH_SIZE=10

# Default AI provider (gemini | openai | anthropic)
DEFAULT_PROVIDER=gemini

# Default AI model to use
DEFAULT_MODEL=gemini-2.5-flash

# Provider timeout in milliseconds
PROVIDER_TIMEOUT=30000

# Maximum retry attempts for provider calls
MAX_RETRIES=3

# Default to dry-run mode for safety (true | false)
DRY_RUN_DEFAULT=true

# =============================================================================
# SECURITY NOTES
# =============================================================================

# 1. Never commit actual API keys to version control
# 2. Use strong, randomly generated API keys
# 3. Rotate API keys regularly
# 4. Use different keys for different environments
# 5. Monitor API key usage and set up alerts

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual API keys and configuration
# 3. Run: npm install
# 4. Run: npm run dev

# =============================================================================
# VERCEL DEPLOYMENT
# =============================================================================

# 1. Set environment variables in Vercel dashboard
# 2. Configure secrets for production API keys
# 3. Deploy: vercel --prod
# 4. Test endpoints with authentication headers

# =============================================================================
# API AUTHENTICATION
# =============================================================================

# All protected endpoints require:
# Header: x-shadowflower-api-key: <SHADOWFLOWER_API_KEY>

# Public endpoints:
# - GET /api/health

# Protected endpoints:
# - POST /api/jobs/moderation/run
# - POST /api/jobs/moderation/dry-run
# - POST /api/jobs/moderation/schedule
# - POST /api/jobs/moderation/rescan (targeted rescan with incremental filters)
# - POST /api/jobs/moderation/reindex (full database reindex - manual, protected)
