# ShadowFlower Environment Configuration

# =============================================================================
# REQUIRED: Core Service Configuration
# =============================================================================

# Base URL for GameDin API endpoints
GAMEDIN_BASE_URL=https://api.gamedin.xyz

# API key for authenticating ShadowFlower service requests
SHADOWFLOWER_API_KEY=your_shadowflower_api_key_here

# API key for server-to-server authentication with GameDin
GAMEDIN_SHADOWFLOWER_API_KEY=your_gamedin_shadowflower_api_key_here

# Allowed CORS origin (restrict to specific domain in production)
ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# REQUIRED: Inter-Service Signing Configuration
# =============================================================================

# Secret key for HMAC signature verification for inter-service requests
# Required for enhanced security between GameDin and ShadowFlower
SHADOWFLOWER_SIGNING_SECRET=your_signing_secret_here_minimum_32_characters

# =============================================================================
# OPTIONAL: Admin Access Configuration
# =============================================================================

# Admin key for accessing protected admin endpoints
# Required for admin gate functionality
SHADOWFLOWER_ADMIN_KEY=your_shadowflower_admin_key_here

# =============================================================================
# OPTIONAL: AI Provider Configuration
# =============================================================================

# Gemini API key for content moderation analysis
# Required if using Gemini provider
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# OPTIONAL: Discord Notification Configuration
# =============================================================================

# Discord webhook URL for sending notifications
# Required for Discord notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Discord channel IDs for different notification types
DISCORD_ALERT_CHANNEL_ID=your_alert_channel_id_here
DISCORD_DIGEST_CHANNEL_ID=your_digest_channel_id_here
DISCORD_ADMIN_CHANNEL_ID=your_admin_channel_id_here

# =============================================================================
# OPTIONAL: Service Configuration
# =============================================================================

# Node environment (development | production)
NODE_ENV=development

# Port for local development (optional, Vercel uses its own)
PORT=3000

# =============================================================================
# OPTIONAL: Moderation Configuration
# =============================================================================

# Default batch size for moderation jobs
DEFAULT_BATCH_SIZE=10

# Default AI provider (gemini | openai | anthropic)
DEFAULT_PROVIDER=gemini

# Default AI model to use
DEFAULT_MODEL=gemini-2.5-flash

# Provider timeout in milliseconds
PROVIDER_TIMEOUT=30000

# Maximum retry attempts for provider calls
MAX_RETRIES=3

# Default to dry-run mode for safety (true | false)
DRY_RUN_DEFAULT=true

# =============================================================================
# SECURITY NOTES
# =============================================================================

# 1. Never commit actual API keys to version control
# 2. Use strong, randomly generated API keys
# 3. Rotate API keys regularly
# 4. Use different keys for different environments
# 5. Monitor API key usage and set up alerts

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================

# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual API keys and configuration
# 3. Run: npm install
# 4. Run: npm run dev

# =============================================================================
# VERCEL DEPLOYMENT
# =============================================================================

# 1. Set environment variables in Vercel dashboard
# 2. Configure secrets for production API keys
# 3. Deploy: vercel --prod
# 4. Test endpoints with authentication headers

# =============================================================================
# API AUTHENTICATION
# =============================================================================

# All protected endpoints require:
# Header: x-shadowflower-api-key: <SHADOWFLOWER_API_KEY>

# Public endpoints:
# - GET /api/health

# Protected endpoints:
# - POST /api/jobs/moderation/run
# - POST /api/jobs/moderation/dry-run
